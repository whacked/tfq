{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tfq/schemas/list.json",
  "title": "List",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["path", "title", "status", "type", "tags"],
    "properties": {
      "path": { "type": "string" },
      "title": { "type": "string" },
      "status": { "type": "string" },
      "type": { "type": "string" },
      "tags": { "type": "array", "items": { "type": "string" } }
    }
  }
}
